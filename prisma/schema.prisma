generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USERS
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  handle        String    @unique
  avatarUrl     String?   @map("avatar_url")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  
  stats         UserStats?
  badges        UserBadge[]
  checkins      Checkin[]
  venueComments VenueComment[]
  posts         Post[]
  postReactions PostReaction[]
  reminders     Reminder[]
  
  @@map("users")
}

model UserStats {
  id           String @id @default(cuid())
  userId       String @unique @map("user_id")
  nightsOut    Int    @default(0) @map("nights_out")
  friendsCount Int    @default(0) @map("friends_count")
  reviewsCount Int    @default(0) @map("reviews_count")
  postsCount   Int    @default(0) @map("posts_count")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_stats")
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  icon        String
  category    String      @default("achievement")
  
  users UserBadge[]
  
  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")
  
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  
  @@unique([userId, badgeId])
  @@map("user_badges")
}

// =============================================================================
// VENUES
// =============================================================================

model Venue {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  streetAddress  String?   @map("street_address")
  city           String?
  state          String?
  lat            Float     @default(0)
  lng            Float     @default(0)
  coverPrice     Decimal?  @map("cover_price") @db.Decimal(10, 2)
  ageRequirement String?   @map("age_requirement")
  genres         String[]  @default([])
  heroImageUrl   String?   @map("hero_image_url")
  isFeatured     Boolean   @default(false) @map("is_featured")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  
  liveData VenueLiveData?
  checkins Checkin[]
  comments VenueComment[]
  events   Event[]
  posts    Post[]
  
  @@map("venues")
}

model VenueLiveData {
  id              String   @id @default(cuid())
  venueId         String   @unique @map("venue_id")
  isOpen          Boolean  @default(true) @map("is_open")
  crowdLevel      String   @default("quiet") @map("crowd_level")
  crowdPercentage Int      @default(0) @map("crowd_percentage")
  checkedInCount  Int      @default(0) @map("checked_in_count")
  litnessScore    Decimal  @default(0) @map("litness_score") @db.Decimal(3, 1)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  
  @@map("venue_live_data")
}

model Checkin {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  venueId      String    @map("venue_id")
  isActive     Boolean   @default(true) @map("is_active")
  checkedInAt  DateTime  @default(now()) @map("checked_in_at")
  checkedOutAt DateTime? @map("checked_out_at")
  
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  posts Post[]
  
  @@map("checkins")
}

model VenueComment {
  id               String   @id @default(cuid())
  venueId          String   @map("venue_id")
  userId           String   @map("user_id")
  content          String
  litnessRating    Int?     @map("litness_rating")
  isVerifiedCheckin Boolean @default(false) @map("is_verified_checkin")
  isHidden         Boolean  @default(false) @map("is_hidden")
  createdAt        DateTime @default(now()) @map("created_at")
  
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("venue_comments")
}

// =============================================================================
// EVENTS
// =============================================================================

model Event {
  id             String    @id @default(cuid())
  venueId        String    @map("venue_id")
  name           String
  slug           String    @unique
  description    String?
  startsAt       DateTime  @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  priceGeneral   Decimal?  @map("price_general") @db.Decimal(10, 2)
  isFree         Boolean   @default(false) @map("is_free")
  isCancelled    Boolean   @default(false) @map("is_cancelled")
  isActive       Boolean   @default(true) @map("is_active")
  attendingCount Int       @default(0) @map("attending_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  reminders Reminder[]
  
  @@map("events")
}

// =============================================================================
// FEED / POSTS
// =============================================================================

model Post {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  venueId          String?  @map("venue_id")
  checkinId        String?  @map("checkin_id")
  contentText      String   @map("content_text")
  isVerifiedCheckin Boolean @default(false) @map("is_verified_checkin")
  isHidden         Boolean  @default(false) @map("is_hidden")
  fireCount        Int      @default(0) @map("fire_count")
  commentCount     Int      @default(0) @map("comment_count")
  createdAt        DateTime @default(now()) @map("created_at")
  
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue?         @relation(fields: [venueId], references: [id], onDelete: SetNull)
  checkin   Checkin?       @relation(fields: [checkinId], references: [id], onDelete: SetNull)
  reactions PostReaction[]
  
  @@map("posts")
}

model PostReaction {
  id           String   @id @default(cuid())
  postId       String   @map("post_id")
  userId       String   @map("user_id")
  reactionType String   @default("fire") @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at")
  
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([postId, userId])
  @@map("post_reactions")
}

// =============================================================================
// REMINDERS
// =============================================================================

model Reminder {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  eventId      String?   @map("event_id")
  reminderType String    @map("reminder_type")
  remindAt     DateTime  @map("remind_at")
  note         String?
  isSent       Boolean   @default(false) @map("is_sent")
  createdAt    DateTime  @default(now()) @map("created_at")
  
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("reminders")
}
